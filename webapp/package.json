{
  "name": "pygments-front",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "author": "PYGMENTS",
  "scripts": {
    "build": "./scripts/next.sh build",
    "start": "./scripts/next.sh start",
    "dev": "./scripts/next.sh dev",
    "check-architecture": "depcruise --config .dependency-cruiser.js --output-type err-long src",
    "check-lint": "eslint --ext .ts,.tsx src",
    "check-types": "tsc -p ./tsconfig.project.json --noEmit",
    "check-format": "prettier --check src/*",
    "format": "prettier --write src",
    "git:getReleasesAndTags": "git tag --points-at HEAD | tr '\\r\\n' ' '",
    "git:getCommitSHA": "git rev-parse HEAD",
    "git:getCommitRef": "git symbolic-ref HEAD",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix --fix-type suggestion",
    "*.{ts,tsx,js,json}": "prettier --write",
    "*.{css,md,yml,yaml}": "prettier --write"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@sanity/client": "5.4.1",
    "@sanity/image-url": "1.0.2",
    "@sanity/webhook": "2.0.0",
    "classnames": "2.3.1",
    "cypress": "7.7.0",
    "framer-motion": "7.3.5",
    "ky": "0.25.1",
    "ky-universal": "0.8.2",
    "next": "12",
    "next-i18next": "8.5.5",
    "postcss": "^8.4.12",
    "querystring": "0.2.1",
    "react": "latest",
    "react-dom": "latest",
    "react-player": "2.10.1",
    "sharp": "0.31.3",
    "swiper": "8.4.4",
    "swr": "0.5.6"
  },
  "devDependencies": {
    "@babel/core": "7.14.6",
    "@mdx-js/react": "1.6.22",
    "@storybook/addon-a11y": "6.4.4",
    "@storybook/addon-actions": "6.4.4",
    "@storybook/addon-docs": "6.4.4",
    "@storybook/addon-essentials": "6.4.4",
    "@storybook/addon-links": "6.4.4",
    "@storybook/addon-postcss": "2.0.0",
    "@storybook/builder-webpack5": "6.4.4",
    "@storybook/manager-webpack5": "6.4.4",
    "@storybook/react": "6.4.4",
    "@teamsupercell/typings-for-css-modules-loader": "2.5.1",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/eslint-plugin": "4.28.3",
    "autoprefixer": "^10.4.0",
    "babel-loader": "8.2.2",
    "dependency-cruiser": "10.0.5",
    "eslint": "7.30.0",
    "eslint-config-next": "11.0.1",
    "eslint-config-react-app": "6.0.0",
    "eslint-plugin-flowtype": "5.8.0",
    "eslint-plugin-import": "2.23.4",
    "eslint-plugin-jsx-a11y": "6.4.1",
    "eslint-plugin-react": "7.24.0",
    "eslint-plugin-react-hooks": "4.2.0",
    "eslint-plugin-storybook": "0.5.1",
    "husky": "7.0.1",
    "i18next-fetch-backend": "3.0.0",
    "lint-staged": "11.0.1",
    "postcss-flexbugs-fixes": "5.0.2",
    "postcss-preset-env": "7.5.0",
    "prettier": "2.3.2",
    "react-i18next": "11.11.4",
    "resize-observer-polyfill": "1.5.1",
    "storybook-addon-next-router": "3.0.10",
    "storybook-addon-paddings": "4.2.1",
    "tailwindcss": "^3.0.7",
    "typescript": "4.3.5",
    "webpack": "5.64.4"
  }
}
